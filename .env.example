# Configuración del Entorno - Ejemplo
# Copia este archivo a .env y ajusta los valores según sea necesario

# Puerto en el que corre el backend (interno en Docker o local)
PORT=3000
# Entorno: development | production
NODE_ENV=development

# Base de Datos (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=support_tickets
DB_PORT=5432
# DB_HOST debe ser 'db' cuando se usa Docker Compose, o 'localhost' para desarrollo local
DB_HOST=localhost

# Seguridad
# IMPORTANTE: Cambia este secreto por una cadena larga y aleatoria
JWT_SECRET=tu_secreto_super_seguro_aqui

# Frontend
# URL de la API para el desarrollo local (fuera de Docker)
VITE_API_URL=http://localhost:3000/api
# URL base del frontend para configurar CORS
FRONTEND_URL=http://localhost:5173

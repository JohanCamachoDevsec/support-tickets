# ==============================================================================
# CONFIGURACIÓN DEL ENTORNO - EJEMPLO
# ==============================================================================
# Copia este archivo a un nuevo archivo llamado .env y ajusta los valores.
# Este archivo sirve como documentación para las variables requeridas.
# ==============================================================================

# PUERTO DEL SERVIDOR (BACKEND)
# Puerto en el que el servidor Express escuchará las peticiones entrantes.
# Por defecto se usa 3000.
PORT=3000

# ENTORNO DE EJECUCIÓN
# 'development' para habilitar logs detallados y debugging.
# 'production' para despliegues optimizados.
NODE_ENV=development

# ==============================================================================
# CONFIGURACIÓN DE LA BASE DE DATOS (POSTGRESQL)
# ==============================================================================

# Usuario administrativo de PostgreSQL
DB_USER=postgres

# Contraseña del usuario de la base de datos
DB_PASSWORD=postgres

# Nombre de la base de datos que se creará y usará
DB_NAME=support_tickets

# Puerto en el que PostgreSQL acepta conexiones
DB_PORT=5432

# HOST DE LA BASE DE DATOS
# Use 'db' si está ejecutando la aplicación dentro de contenedores Docker Compose.
# Use 'localhost' si está ejecutando el backend localmente con una BD externa.
DB_HOST=localhost

# ==============================================================================
# SEGURIDAD Y AUTENTICACIÓN
# ==============================================================================

# JWT SECRET
# Clave secreta para firmar y verificar los tokens de acceso JSON Web Tokens.
# IMPORTANTE: Use una cadena larga, aleatoria y compleja en producción.
JWT_SECRET=tu_secreto_super_seguro_para_desarrollo_local

# ==============================================================================
# CONFIGURACIÓN DEL FRONTEND (VITE)
# ==============================================================================

# URL BASE DE LA API
# El frontend usará esta dirección para realizar todas las peticiones al backend.
# En desarrollo local: http://localhost:3000/api
# En producción: /api (gracias al proxy de Nginx)
VITE_API_URL=http://localhost:3000/api

# URL DEL FRONTEND (PARA CORS)
# Utilizada por el backend para permitir peticiones desde este origen.
FRONTEND_URL=http://localhost:5173
